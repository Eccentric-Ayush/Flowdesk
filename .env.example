# ════════════════════════════════════════════════
#  FlowDesk — Environment Variables Template
#
#  HOW TO USE:
#    1. Copy this file:  cp .env.example .env
#    2. Fill in your real values from Supabase Dashboard
#    3. NEVER commit .env — it's git-ignored
# ════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ── App Settings ─────────────────────────────────
VITE_APP_NAME="FlowDesk"
VITE_API_VERSION=v1

# ── Server-Side Only (NEVER prefix with VITE_) ───
# ⚠️  Only use this in Supabase Edge Functions or a secure backend.
#     It bypasses Row Level Security — do NOT expose it in browser code.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
